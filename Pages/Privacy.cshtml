@page
@model PrivacyModel
@{
    ViewData["Title"] = "О нас - StepStyle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <h1 class="text-center mb-5 display-4">О магазине StepStyle</h1>
            
            <div class="card shadow-sm mb-4">
                <div class="card-body p-5">
                    <h3 class="card-title mb-4"><i class="bi bi-shop text-primary"></i> Наша история</h3>
                    <p class="card-text lead">
                        StepStyle — это современный магазин качественной обуви, основанный в 2020 году. 
                        Мы предлагаем широкий ассортимент мужской, женской и детской обуви на любой вкус и бюджет.
                    </p>
                    <p class="card-text">
                        Наша миссия — сделать стильную и комфортную обувь доступной для каждого. 
                        Мы тщательно отбираем каждую модель, обращая внимание на качество материалов, 
                        удобство и актуальность дизайна.
                    </p>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body p-4">
                            <h4 class="card-title"><i class="bi bi-check-circle-fill text-success"></i> Наши преимущества</h4>
                            <ul class="list-unstyled mt-3">
                                <li class="mb-2"><i class="bi bi-check2 text-primary"></i> Только оригинальная продукция</li>
                                <li class="mb-2"><i class="bi bi-check2 text-primary"></i> Бесплатная доставка от 5000 ₽</li>
                                <li class="mb-2"><i class="bi bi-check2 text-primary"></i> Возврат в течение 30 дней</li>
                                <li class="mb-2"><i class="bi bi-check2 text-primary"></i> Гарантия качества</li>
                                <li class="mb-2"><i class="bi bi-check2 text-primary"></i> Профессиональная консультация</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body p-4">
                            <h4 class="card-title"><i class="bi bi-geo-alt-fill text-danger"></i> Контакты</h4>
                            <ul class="list-unstyled mt-3">
                                <li class="mb-2"><strong>Адрес:</strong> Москва, ул. Примерная, 123</li>
                                <li class="mb-2"><strong>Телефон:</strong> +7 (999) 123-45-67</li>
                                <li class="mb-2"><strong>Email:</strong> info@stepstyle.ru</li>
                                <li class="mb-2"><strong>Режим работы:</strong></li>
                                <li class="mb-2 ms-3">Пн-Пт: 10:00 - 21:00</li>
                                <li class="ms-3">Сб-Вс: 11:00 - 20:00</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-5 text-center">
                    <h3 class="mb-4">Подписывайтесь на нас</h3>
                    <div class="d-flex justify-content-center gap-4">
                        <a href="#" class="text-decoration-none">
                            <i class="bi bi-instagram" style="font-size: 3rem; color: #E4405F;"></i>
                            <p class="mt-2 mb-0 text-muted">Instagram</p>
                        </a>
                        <a href="#" class="text-decoration-none">
                            <i class="bi bi-telegram" style="font-size: 3rem; color: #0088cc;"></i>
                            <p class="mt-2 mb-0 text-muted">Telegram</p>
                        </a>
                        <a href="#" class="text-decoration-none">
                            <i class="bi bi-whatsapp" style="font-size: 3rem; color: #25D366;"></i>
                            <p class="mt-2 mb-0 text-muted">WhatsApp</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
