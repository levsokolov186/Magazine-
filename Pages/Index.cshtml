@section Scripts {
    <script>
        function openProduct(name, category, price, emoji, oldPrice) {
            var url = '/Product?name=' + encodeURIComponent(name) + 
                      '&category=' + encodeURIComponent(category) + 
                      '&price=' + price + 
                      '&emoji=' + encodeURIComponent(emoji);
            if (oldPrice) {
                url += '&oldPrice=' + oldPrice + '&badge=-' + Math.round((1 - price / oldPrice) * 100) + '%';
            } else {
                url += '&badge=Новинка';
            }
            window.location.href = url;
        }

        function quickAddToCart(btn, name, price) {
            // Быстрое добавление — перенаправляем на страницу товара для выбора размера
            var card = btn.closest('.product-card');
            card.click();
        }
    </script>
}
