@section Scripts {
    <script>
        var cart = JSON.parse(localStorage.getItem('cart') || '[]');
        var favorites = JSON.parse(localStorage.getItem('favorites') || '[]');

        function updateCartCount() {
            var count = cart.reduce(function(sum, item) { return sum + item.quantity; }, 0);
            $('#cartCount').text(count);
        }

        function updateFavoritesCount() {
            $('#favoritesCount').text(favorites.length);
        }

        function addToCart(name, price) {
            var existingItem = null;
            for (var i = 0; i < cart.length; i++) {
                if (cart[i].name === name) {
                    existingItem = cart[i];
                    break;
                }
            }
            if (existingItem) {
                existingItem.quantity++;
            } else {
                cart.push({ name: name, price: price, quantity: 1 });
            }
            localStorage.setItem('cart', JSON.stringify(cart));
            updateCartCount();
            
            var btn = event.target;
            var originalText = btn.textContent;
            btn.textContent = '✓ Добавлено';
            btn.classList.add('btn-success');
            setTimeout(function() {
                btn.textContent = originalText;
                btn.classList.remove('btn-success');
            }, 1500);
        }

        function toggleFavorite(btn) {
            var productName = btn.getAttribute('data-product');
            var icon = btn.querySelector('i');
            var index = favorites.indexOf(productName);
            
            if (index > -1) {
                favorites.splice(index, 1);
                icon.classList.remove('bi-heart-fill');
                icon.classList.add('bi-heart');
                btn.classList.remove('active');
            } else {
                favorites.push(productName);
                icon.classList.remove('bi-heart');
                icon.classList.add('bi-heart-fill');
                btn.classList.add('active');
            }
            
            localStorage.setItem('favorites', JSON.stringify(favorites));
            updateFavoritesCount();
        }

        $(document).ready(function() {
            updateCartCount();
            updateFavoritesCount();
            
            $('.btn-favorite').each(function() {
                var productName = $(this).data('product');
                if (favorites.indexOf(productName) > -1) {
                    var icon = $(this).find('i')[0];
                    icon.classList.remove('bi-heart');
                    icon.classList.add('bi-heart-fill');
                    $(this).addClass('active');
                }
            });
        });
    </script>
}
