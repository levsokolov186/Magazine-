@page
@model IndexModel

@{
    ViewData["Title"] = "StepStyle — Женская обувь";
}

<!-- Products Section -->
<section id="products" class="products-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Каталог</h2>
        </div>
        <div class="row g-4">
            @if (Model.Products.Any())
            {
                @foreach (var product in Model.Products)
                {
                    var badge = product.OldPrice.HasValue ? $"-{Math.Round((1 - (double)product.Price / (double)product.OldPrice.Value) * 100)}%" : "Новинка";
                    <div class="col-md-4 col-lg-3">
                        <div class="product-card" onclick="openProduct('@product.Name.Replace("'", "\\'")', '@product.Category.Replace("'", "\\'")', @product.Price, '@product.Emoji')">
                            <div class="product-image">
                                <div class="placeholder-img"><span>@product.Emoji</span></div>
                                @if (product.OldPrice.HasValue)
                                {
                                    <span class="badge-sale">@badge</span>
                                }
                                else
                                {
                                    <span class="badge-new">@badge</span>
                                }
                            </div>
                            <div class="product-info">
                                <h5 class="product-name">@product.Name</h5>
                                <p class="product-category">@product.Category</p>
                                <p class="product-hint text-muted mb-2"><small><i class="bi bi-hand-index me-1"></i>Нажмите, чтобы выбрать размер</small></p>
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <div>
                                        <span class="product-price">@product.Price.ToString("N0").Replace(",", " ") ₽</span>
                                        @if (product.OldPrice.HasValue)
                                        {
                                            <br><small class="text-muted text-decoration-line-through">@product.OldPrice.Value.ToString("N0").Replace(",", " ") ₽</small>
                                        }
                                    </div>
                                    <button class="btn btn-cart" onclick="event.stopPropagation(); openProduct('@product.Name.Replace("'", "\\'")', '@product.Category.Replace("'", "\\'")', @product.Price, '@product.Emoji')">
                                        <i class="bi bi-cart-plus"></i> В корзину
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5 text-muted">
                    <i class="bi bi-inbox" style="font-size: 5rem;"></i>
                    <p class="mt-3">Товары скоро появятся</p>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function openProduct(name, category, price, emoji, oldPrice) {
            var badge = oldPrice ? '-' + Math.round((1 - price / oldPrice) * 100) + '%' : 'Новинка';
            navigateToProduct(name, price, emoji, badge);
        }

        $(document).ready(function() {
            updateNavCounts();
        });
    </script>
}
