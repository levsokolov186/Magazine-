@page
@model FavoritesModel
@{
    ViewData["Title"] = "Избранное — StepStyle";
}

<div class="container py-5">
    <div class="page-header">
        <h1><i class="bi bi-heart-fill"></i> Избранное</h1>
    </div>
    
    <div id="favoritesContainer">
        <!-- Empty state -->
        <div class="empty-state" id="emptyFavoritesMessage">
            <i class="bi bi-heart" style="font-size: 5rem;"></i>
            <h3>В избранном пусто</h3>
            <p class="mb-4">Нажмите на сердечко в каталоге, чтобы добавить товар</p>
            <a href="/" class="btn btn-primary btn-lg">
                <i class="bi bi-handbag me-2"></i>Перейти в каталог
            </a>
        </div>
        
        <!-- Favorites content -->
        <div class="row g-4" id="favoritesContent" style="display: none;">
            <!-- Will be rendered dynamically -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
        var cart = JSON.parse(localStorage.getItem('cart') || '[]');

        var allProducts = [
            { name: 'Туфли Elegance', category: 'Женские туфли', price: 6390, emoji: '👠' },
            { name: 'Сапоги Winter Comfort', category: 'Женские сапоги', price: 9990, emoji: '👢' },
            { name: 'Балетки Soft Step', category: 'Женские балетки', price: 4290, emoji: '🥿' },
            { name: 'Сандалии Summer Breeze', category: 'Женские сандалии', price: 3990, emoji: '👡' },
            { name: 'Ботильоны Chelsea', category: 'Женские ботильоны', price: 8490, emoji: '👢' },
            { name: 'Кроссовки Lady Sport', category: 'Женские кроссовки', price: 7490, emoji: '👟' },
            { name: 'Лоферы Classic', category: 'Женские лоферы', price: 5990, emoji: '👠' },
            { name: 'Сапоги-трубы Luxe', category: 'Женские сапоги', price: 14990, emoji: '👢' }
        ];

        function formatPrice(price) {
            return price.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ') + ' ₽';
        }

        function addToCart(name, price) {
            var existingItem = null;
            for (var i = 0; i < cart.length; i++) {
                if (cart[i].name === name) {
                    existingItem = cart[i];
                    break;
                }
            }
            if (existingItem) {
                existingItem.quantity++;
            } else {
                cart.push({ name: name, price: price, quantity: 1 });
            }
            localStorage.setItem('cart', JSON.stringify(cart));
            
            var count = cart.reduce(function(sum, item) { return sum + item.quantity; }, 0);
            $('#cartCount').text(count);
            
            // Show toast notification
            showToast(name + ' добавлен в корзину!');
        }

        function removeFromFavorites(name) {
            var index = favorites.indexOf(name);
            if (index > -1) {
                favorites.splice(index, 1);
            }
            localStorage.setItem('favorites', JSON.stringify(favorites));
            renderFavorites();
        }

        function showToast(message) {
            var toast = $('<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">' +
                '<div class="toast show" role="alert" style="background: var(--bg-surface); border: 1px solid var(--border-color); color: var(--text-primary);">' +
                    '<div class="toast-body">' +
                        '<i class="bi bi-check-circle-fill text-success me-2"></i>' + message +
                    '</div>' +
                '</div>' +
            '</div>');
            
            $('body').append(toast);
            setTimeout(function() {
                toast.fadeOut(300, function() { $(this).remove(); });
            }, 2500);
        }

        function renderFavorites() {
            var emptyMessage = document.getElementById('emptyFavoritesMessage');
            var favoritesContent = document.getElementById('favoritesContent');
            
            if (favorites.length === 0) {
                emptyMessage.style.display = 'block';
                favoritesContent.style.display = 'none';
                $('#favoritesCount').text(0);
                return;
            }
            
            emptyMessage.style.display = 'none';
            favoritesContent.style.display = 'flex';
            $('#favoritesCount').text(favorites.length);
            
            favoritesContent.innerHTML = '';
            
            for (var i = 0; i < favorites.length; i++) {
                var favName = favorites[i];
                var product = null;
                for (var j = 0; j < allProducts.length; j++) {
                    if (allProducts[j].name === favName) {
                        product = allProducts[j];
                        break;
                    }
                }
                
                if (!product) continue;
                
                var itemHtml = '<div class="col-md-4 col-lg-3">' +
                    '<div class="product-card">' +
                        '<div class="product-image">' +
                            '<div class="placeholder-img">' +
                                '<span>' + product.emoji + '</span>' +
                            '</div>' +
                            '<button class="btn-favorite active" onclick="removeFromFavorites(\'' + product.name + '\')">' +
                                '<i class="bi bi-heart-fill"></i>' +
                            '</button>' +
                        '</div>' +
                        '<div class="product-info">' +
                            '<h5 class="product-name">' + product.name + '</h5>' +
                            '<p class="product-category">' + product.category + '</p>' +
                            '<div class="d-flex justify-content-between align-items-center mt-auto">' +
                                '<span class="product-price">' + formatPrice(product.price) + '</span>' +
                                '<button class="btn btn-cart" onclick="addToCart(\'' + product.name + '\', ' + product.price + ')">' +
                                    '<i class="bi bi-cart-plus"></i> В корзину' +
                                '</button>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                '</div>';
                
                favoritesContent.innerHTML += itemHtml;
            }
        }

        $(document).ready(function() {
            renderFavorites();
        });
    </script>
}
