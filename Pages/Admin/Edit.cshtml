@page
@model ShoesStore.Pages.Admin.EditModel
@{
    ViewData["Title"] = "Редактировать товар";
}

<div class="container py-5">
    <div class="mb-4">
        <a asp-page="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Назад к списку
        </a>
    </div>

    <h1 class="mb-4"><i class="bi bi-pencil"></i> Редактировать товар</h1>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Product.Id" />

                        <div class="mb-3">
                            <label asp-for="Product.Name" class="form-label"></label>
                            <input asp-for="Product.Name" class="form-control" />
                            <span asp-validation-for="Product.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Product.Description" class="form-label"></label>
                            <textarea asp-for="Product.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Product.Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Product.Price" class="form-label"></label>
                                <input asp-for="Product.Price" class="form-control" type="number" min="0" step="0.01" />
                                <span asp-validation-for="Product.Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Product.OldPrice" class="form-label"></label>
                                <input asp-for="Product.OldPrice" class="form-control" type="number" min="0" step="0.01" />
                                <span asp-validation-for="Product.OldPrice" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Product.Category" class="form-label"></label>
                                <input asp-for="Product.Category" class="form-control" />
                                <span asp-validation-for="Product.Category" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Product.Emoji" class="form-label"></label>
                                <input asp-for="Product.Emoji" class="form-control" />
                                <span asp-validation-for="Product.Emoji" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Product.Material" class="form-label"></label>
                                <input asp-for="Product.Material" class="form-control" />
                                <span asp-validation-for="Product.Material" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Product.Color" class="form-label"></label>
                                <input asp-for="Product.Color" class="form-control" />
                                <span asp-validation-for="Product.Color" class="text-danger"></span>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Управление размерами -->
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-rulers"></i> Размеры и наличие</h5>
                </div>
                <div class="card-body p-4">
                    <!-- Добавление нового размера -->
                    <form method="post" class="row g-2 align-items-end mb-4">
                        <div class="col-auto">
                            <label class="form-label">Добавить размер:</label>
                        </div>
                        <div class="col-auto">
                            <input type="number" name="newSize" class="form-control" step="0.5" min="20" max="50" placeholder="Напр: 37.5" style="width: 120px;" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" name="action" value="add" class="btn btn-success btn-sm">
                                <i class="bi bi-plus-lg me-1"></i>Добавить
                            </button>
                        </div>
                    </form>

                    <!-- Таблица размеров -->
                    @if (Model.SizeEntries.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Размер</th>
                                        <th>Статус</th>
                                        <th class="text-end">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in Model.SizeEntries.OrderBy(s => s.Size))
                                    {
                                        <tr>
                                            <td>
                                                <strong class="fs-5">@entry.Size</strong>
                                            </td>
                                            <td>
                                                @if (entry.InStock)
                                                {
                                                    <span class="badge bg-success fs-6">
                                                        <i class="bi bi-check-lg me-1"></i>В наличии
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary fs-6">
                                                        <i class="bi bi-x-lg me-1"></i>Нет в наличии
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <form method="post" class="d-inline">
                                                    <button type="submit" name="action" value="toggle" 
                                                            class="btn btn-sm btn-outline-warning me-1" title="Переключить наличие">
                                                        <i class="bi bi-arrow-repeat"></i>
                                                    </button>
                                                    <button type="submit" name="action" value="remove" 
                                                            class="btn btn-sm btn-outline-danger" title="Удалить размер"
                                                            onclick="return confirm('Удалить размер @entry.Size?')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                    <input type="hidden" name="newSize" value="@entry.Size" />
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">
                            <i class="bi bi-info-circle me-2"></i>Добавьте размеры для этого товара
                        </p>
                    }

                    <div class="mt-3">
                        <form method="post">
                            <button type="submit" name="action" value="save" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-lg me-2"></i>Сохранить изменения
                            </button>
                            <a asp-page="Index" class="btn btn-outline-secondary btn-lg">Отмена</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card sticky-top" style="top: 1rem; z-index: 100;">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">Информация</h5>
                    <div class="text-center mb-3">
                        <div class="rounded-4 d-flex align-items-center justify-content-center mb-3" 
                             style="height: 200px; background: var(--bg-product-img, #f0f0f0); font-size: 6rem;">
                            @Model.Product.Emoji
                        </div>
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted">Создан:</dt>
                        <dd class="col-sm-7">@Model.Product.CreatedAt.ToString("dd.MM.yyyy")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
